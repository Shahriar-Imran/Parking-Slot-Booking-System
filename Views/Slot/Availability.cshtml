@model ParkingSystem.ViewModels.SlotAvailabilityViewModel

<div id="authData" data-auth="@(User.Identity.IsAuthenticated.ToString().ToLower())">

    <div class="container mt-4">

        <h2 class="mb-4">Slot Availability</h2>

        <!-- SEARCH FORM -->
        <form method="post">

            <!-- DATE -->
            <div class="mb-3">
                <label>Select Date & Time</label>
                <input id="dateInput"
                       name="Date"
                       type="datetime-local"
                       class="form-control"
                       value="@Model.Date.ToString("yyyy-MM-ddTHH:mm")"
                       step="60"
                       required />
            </div>

            <!-- DURATION -->
            <div class="mb-3">
                <label>Duration (Hours)</label>
                <input id="durationInput"
                       name="DurationHours"
                       type="number"
                       class="form-control"
                       value="@Model.DurationHours"
                       min="1"
                       required />
            </div>

            <button type="submit" class="btn btn-primary">Search</button>
        </form>

        <hr />

        <!-- SLOT GRID -->
        @if (Model.AvailableSlots != null && Model.AvailableSlots.Any())
        {
            var grouped = Model.AvailableSlots
            .GroupBy(s => new { s.ParkingArea.BlockNumber, s.ParkingArea.VehicleType });

            foreach (var group in grouped)
            {
                var area = group.First().ParkingArea;

                <div class="mt-4">
                    <h5 class="text-primary">
                        Block @area.BlockNumber - @area.VehicleType (৳ @area.HourlyRate/hr)
                    </h5>

                    <div class="row">

                        @foreach (var slot in group)
                        {
                            <div class="col-md-2 mb-2">
                                <button type="button"
                                        class="btn btn-outline-success slot-btn"
                                        data-id="@slot.SlotId"
                                        data-rate="@slot.ParkingArea.HourlyRate">
                                    @slot.SlotNumber
                                </button>
                            </div>
                        }

                    </div>
                </div>
            }

            <!-- SELECTED COUNT -->
            <p class="mt-3 fw-bold">
                Selected Slots: <span id="countDisplay">0</span>
            </p>

            <!-- TOTAL -->
            <p class="fw-bold text-success">
                Total Amount: <span id="totalAmount">৳ 0</span>
            </p>

            <!-- BOOK BUTTON -->
            <button type="button" class="btn btn-success mt-2" onclick="bookSlots()">
                Book Now
            </button>
        }

    </div>
</div>