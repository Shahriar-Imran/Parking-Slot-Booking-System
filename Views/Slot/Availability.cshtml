@model ParkingSystem.ViewModels.SlotAvailabilityViewModel
@using System.Text.Json

<div id="authData" data-auth="@(User.Identity.IsAuthenticated.ToString().ToLower())" data-userid="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value">

    <div class="container mt-4">

        <h2 class="mb-4 fw-bold">Slot Availability</h2>

        <!-- SEARCH FORM -->
        <div class="card p-3 shadow-sm mb-4">
            <form method="post" class="row g-3">

                <div class="col-md-6">
                    <label>Select Date & Time</label>
                    <input id="dateInput"
                           name="Date"
                           type="datetime-local"
                           class="form-control"
                           value="@Model.Date.ToString("yyyy-MM-ddTHH:mm")"
                           step="60"
                           required />
                </div>

                <div class="col-md-4">
                    <label>Duration (Hours)</label>
                    <input id="durationInput"
                           name="DurationHours"
                           type="number"
                           class="form-control"
                           value="@Model.DurationHours"
                           min="1"
                           required />
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        Search
                    </button>
                </div>

            </form>
        </div>

        <!-- SLOT GRID -->
        @if (Model.AvailableSlots != null && Model.AvailableSlots.Any())
        {
            <!-- LEGEND -->
            <div class="legend-box mb-3">
                <span><span class="legend-color border"></span> Available</span>
                <span><span class="legend-color bg-success"></span> Selected</span>
                <span><span class="legend-color bg-secondary"></span> Booked</span>
            </div>

            var grouped = Model.AvailableSlots
            .GroupBy(s => new { s.ParkingArea.BlockNumber, s.ParkingArea.VehicleType });

            foreach (var group in grouped)
            {
                var area = group.First().ParkingArea;

                <div class="slot-container mb-3">

                    <!-- DROPDOWN HEADER -->
                    <div class="block-header d-flex justify-content-between align-items-center"
                         onclick="toggleBlock('block-@area.BlockNumber-@area.VehicleType')">

                        <span>
                            Block @area.BlockNumber - @area.VehicleType
                            (৳ @area.HourlyRate/hr)
                        </span>

                        <span class="badge bg-primary"
                              id="count-@area.BlockNumber-@area.VehicleType">

                            Available: @group.Count(s =>
                          !(ViewBag.BookedSlots as List<int>).Contains(s.SlotId))

                        </span>

                    </div>
                    

                    <!-- SLOT GRID -->
                    <div id="block-@area.BlockNumber-@area.VehicleType" style="display:none;">

                        <div class="slot-grid">

                            @foreach (var slot in group)
                            {
                                var isUnavailable = ViewBag.BookedSlots != null &&
                                ((List<int>)ViewBag.BookedSlots).Contains(slot.SlotId);

                                <button type="button"
                                        class="btn slot-btn @(isUnavailable ? "btn-secondary disabled-slot" : "btn-outline-success")"
                                        data-id="@slot.SlotId"
                                        data-rate="@slot.ParkingArea.HourlyRate"
                                        data-area="@area.BlockNumber-@area.VehicleType"
                                @(isUnavailable ? "disabled" : "")>

                                    @slot.SlotNumber

                                    <small class="d-block timer" id="timer-@slot.SlotId"></small>
                                </button>
                            }

                        </div>

                    </div>

                </div>
            }

            <!-- SUMMARY CARD -->
            <div class="card mt-4 p-3 shadow-sm">
                <h5>Booking Summary</h5>

                <p class="fw-bold text-success fs-5">
                    Total: ৳ <span id="totalAmount">0</span>
                </p>

                <p>
                    Selected Slots:
                    <strong id="countDisplay">0</strong>
                </p>

                <button type="button"
                        class="btn btn-success w-100 mt-2"
                        onclick="bookSlots()">
                    Continue Booking
                </button>
            </div>
        }

    </div>
</div>

<!-- ============================= -->
<!-- 🔥 SCRIPTS -->
<!-- ============================= -->

<script>
    function toggleBlock(id) {
        const el = document.getElementById(id);
        el.style.display = (el.style.display === "none") ? "block" : "none";
    }
</script>

<script>
    var lockTimes = @Html.Raw(JsonSerializer.Serialize(ViewBag.LockTimes ?? new List<object>()));
    console.log("LOCK TIMES:", lockTimes);
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script src="~/js/slot.js"></script>

<script src="~/js/slot.js"></script>