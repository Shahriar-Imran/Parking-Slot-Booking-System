@model ParkingSystem.ViewModels.SlotAvailabilityViewModel
@using System.Text.Json

<style>
    .timer-text { color: #8e959b; }
</style>

<div id="authData" data-auth="@(User.Identity.IsAuthenticated.ToString().ToLower())" data-userid="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value">

    <div class="container mt-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold" style="color: var(--primary-color);">Find Your Slot</h2>
                <p class="text-muted mb-0">Select your preferred time and block to park securely.</p>
            </div>
        </div>

        <!-- TOP SECTION WITH IMAGE & SEARCH -->
        <div class="row mb-5 align-items-center">

            <div class="col-lg-7 order-2 order-lg-1 mb-4 mb-lg-0">
                <div class="card p-4 shadow-sm mb-0 border-0 rounded-4 h-100" style="background: var(--surface-color);">
                    <form method="post" class="row g-3 align-items-end h-100">

                        <div class="col-md-5">
                            <label>Select Date & Time</label>
                            <input id="dateInput"
                                   name="Date"
                                   type="datetime-local"
                                   class="form-control"
                                   value="@Model.Date.ToString("yyyy-MM-ddTHH:mm")"
                                   min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
                                   step="60"
                                   required />
                        </div>

                        <div class="col-md-4">
                            <label>Duration (Hours)</label>
                            <input id="durationInput"
                                   name="DurationHours"
                                   type="number"
                                   class="form-control"
                                   value="@Model.DurationHours"
                                   min="1"
                                   required />
                        </div>

                        <div class="col-md-3 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100 rounded-3 shadow-sm py-2">
                                <i class="fas fa-search"></i> Search
                            </button>
                        </div>

                    </form>
                </div>
            </div>
            
            <div class="col-lg-5 order-1 order-lg-2 mb-4 mb-lg-0">
                <div class="rounded-4 overflow-hidden shadow-sm position-relative" style="height: 220px; background: #e9ecef;">
                    <img src="~/images/parkingimage2.jpg" alt="Parking Display" class="w-100 h-100 object-fit-cover" style="filter: brightness(0.85);" />
                    <div class="position-absolute bottom-0 start-0 w-100 p-3" style="background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);">
                        <h5 class="text-white mb-0 fw-bold"><i class="fas fa-shield-alt text-warning me-2"></i>Secure Your Spot</h5>
                        <p class="text-white-50 small mb-0">Fast & easy booking process.</p>
                    </div>
                </div>
            </div>

        </div>

        <!-- SLOT GRID -->
        @if (Model.AvailableSlots != null && Model.AvailableSlots.Any())
        {
            <div class="row">
                <!-- MAIN SLOTS AREA -->
                <div class="col-lg-8">
                    
                    <!-- LEGEND -->
                    <div class="legend-box mb-4 p-3 bg-white rounded-3 shadow-sm d-flex gap-3 flex-wrap border">
                        <span class="d-flex align-items-center gap-1"><span class="legend-color border bg-white shadow-sm"></span> <small class="fw-bold text-muted">Available</small></span>
                        <span class="d-flex align-items-center gap-1"><span class="legend-color" style="background: #28a745;"></span> <small class="fw-bold text-muted">Selected</small></span>
                        <span class="d-flex align-items-center gap-1"><span class="legend-color bg-secondary opacity-50"></span> <small class="fw-bold text-muted">Booked</small></span>
                    </div>

                    @{
                        var grouped = Model.AvailableSlots
                        .GroupBy(s => new { s.ParkingArea.BlockNumber, s.ParkingArea.VehicleType });
                    }

                    @foreach (var group in grouped)
                    {
                        var area = group.First().ParkingArea;

                        <div class="slot-container mb-4 outline-none border border-light">
                            <!-- DROPDOWN HEADER -->
                            <div class="block-header d-flex justify-content-between align-items-center shadow-sm"
                                 onclick="toggleBlock('block-@area.BlockNumber-@area.VehicleType')">

                                <div class="d-flex align-items-center gap-3">
                                    <h5 class="mb-0 fw-bold" style="color: var(--primary-color);">Block @area.BlockNumber</h5>
                                    <span class="badge bg-light text-dark shadow-sm border px-3 py-2 rounded-pill">@area.VehicleType</span>
                                    <span class="text-muted small">৳ @area.HourlyRate/hr</span>
                                </div>

                                <span class="badge rounded-pill px-3 py-2 text-white shadow-sm"
                                      style="background: linear-gradient(135deg, var(--secondary-color), #00d4ff);"
                                      id="count-@area.BlockNumber-@area.VehicleType">
                                    Available: @group.Count(s => !(ViewBag.BookedSlots as List<int>).Contains(s.SlotId))
                                </span>
                            </div>

                            <!-- SLOT GRID -->
                            <div id="block-@area.BlockNumber-@area.VehicleType" style="display:none;" class="mt-3 bg-light p-3 rounded-4">
                                <div class="slot-grid mt-0 p-0">
                                    @foreach (var slot in group)
                                    {
                                        var isUnavailable = ViewBag.BookedSlots != null &&
                                        ((List<int>)ViewBag.BookedSlots).Contains(slot.SlotId);

                                        <button type="button"
                                                class="btn slot-btn @(isUnavailable ? "disabled-slot" : "available-slot bg-white shadow-sm pt-2 pb-1 border") d-flex flex-column align-items-center justify-content-center position-relative p-1"
                                                data-id="@slot.SlotId"
                                                data-rate="@slot.ParkingArea.HourlyRate"
                                                data-area="@area.BlockNumber-@area.VehicleType"
                                                style="border-radius: 12px; min-height: 55px;"
                                        @(isUnavailable ? "disabled" : "")>
                                            
                                            <span class="fw-bold custom-slot-text" style="font-size: 0.85rem; line-height: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%;">@slot.SlotNumber</span>
                                            <small class="d-block timer timer-text mt-1 w-100 text-truncate" style="font-size: 0.6rem;" id="timer-@slot.SlotId"></small>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- SIDEBAR SUMMARY -->
                <div class="col-lg-4">
                    <div class="card p-4 shadow-sm border-0 rounded-4" style="background: linear-gradient(135deg, var(--primary-color), var(--secondary-color)); color: white; position: sticky; top: 100px;">
                        <h4 class="fw-bold mb-4"><i class="fas fa-file-invoice-dollar me-2"></i>Booking Summary</h4>
                        
                        <div class="p-3 rounded-3 mb-4 flex-grow-1" style="background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(10px);">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-white-50 flex-grow-1">Selected Slots:</span>
                                <strong id="countDisplay" class="fs-5">0</strong>
                            </div>
                            <hr class="border-light opacity-25">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-white-50">Total Estimation:</span>
                                <span class="fw-bold fs-3 text-warning"> <span id="totalAmount">0</span></span>
                            </div>
                        </div>

                        <button type="button"
                                class="btn btn-warning btn-lg w-100 rounded-pill shadow fw-bold d-flex align-items-center justify-content-center gap-2"
                                style="color: var(--primary-color);"
                                onclick="bookSlots()">
                            Continue Booking <i class="fas fa-arrow-right"></i>
                        </button>
                    </div>
                </div>
            </div>
        }

    </div>
</div>

<!-- ============================= -->
<!-- 🔥 SCRIPTS -->
<!-- ============================= -->

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Enforce strict client-side time-walls to prevent past reservations
        const dateInput = document.getElementById('dateInput');
        if (dateInput) {
            const now = new Date();
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const day = String(now.getDate()).padStart(2, '0');
            const hours = String(now.getHours()).padStart(2, '0');
            const minutes = String(now.getMinutes()).padStart(2, '0');
            
            const minDateTime = `${year}-${month}-${day}T${hours}:${minutes}`;
            dateInput.min = minDateTime;
            
            // Safely cascade values forward if the system initializes with a past timestamp
            if (dateInput.value && dateInput.value < minDateTime) {
                dateInput.value = minDateTime;
            }
        }
    });

    function toggleBlock(id) {
        const el = document.getElementById(id);
        if(el.style.display === "none") {
            el.style.display = "block";
            el.style.opacity = "0";
            setTimeout(() => el.style.opacity = "1", 10);
            el.style.transition = "opacity 0.3s ease";
        } else {
            el.style.opacity = "0";
            setTimeout(() => el.style.display = "none", 300);
        }
    }
</script>

<script>
    var lockTimes = @Html.Raw(JsonSerializer.Serialize(ViewBag.LockTimes ?? new List<object>()));
    console.log("LOCK TIMES:", lockTimes);
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script src="~/js/slot.js"></script>