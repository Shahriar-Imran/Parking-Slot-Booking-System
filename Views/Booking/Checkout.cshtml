@model List<ParkingSystem.Models.ParkingSlot>

<div class="container mt-4">

    <h2>Booking Confirmation</h2>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Slot</th>
                <th>Area</th>
                <th>Rate</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var slot in Model)
            {
                <tr>
                    <td>@slot.SlotNumber</td>
                    <td>@slot.ParkingArea.VehicleType (Block @slot.ParkingArea.BlockNumber)</td>
                    <td>৳ @slot.ParkingArea.HourlyRate</td>
                </tr>
            }
        </tbody>
    </table>

    <h4>Duration: @ViewBag.Duration hour(s)</h4>
    <h3>Total: ৳ @ViewBag.Total</h3>

    <form method="post" asp-controller="Payment" asp-action="ProcessPayment">

        <input type="hidden" name="slots" value="@string.Join(",", Model.Select(s => s.SlotId))" />
        <input type="hidden" name="duration" value="@ViewBag.Duration" />
        <input type="hidden" name="total" value="@ViewBag.Total" />
        @{
            var bookingDate = ViewBag.Date as DateTime?;
        }
        <input type="hidden"
               name="date"
               value="@(bookingDate.HasValue ? bookingDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
        <p>DEBUG DATE: @ViewBag.Date</p>

        <button class="btn btn-success">
            Proceed to Payment
        </button>

    </form>

</div>