@model ApplicationUser

@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center mt-4 mb-5 align-items-center" style="min-height: 60vh;">
    <div class="col-md-6 col-lg-5 col-xl-4">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden" style="background: var(--surface-color);">
            
            <div class="card-header border-0 text-center text-white py-4" style="background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));">
                <h4 class="fw-bold mb-0">My Profile</h4>
            </div>

            <div class="card-body p-4 text-center">
                <div class="mb-4 position-relative d-inline-block">
                    <img src="@Model.ProfileImage" class="rounded-circle shadow-sm border border-3 border-white object-fit-cover" style="width: 130px; height: 130px;" alt="Profile Picture" />
                </div>

                <h4 class="fw-bold text-dark mb-1">@Model.FullName</h4>
                <p class="text-muted small mb-4"><i class="fas fa-envelope me-2 text-primary"></i>@Model.Email</p>

                <ul class="list-group list-group-flush text-start mb-4">
                    <li class="list-group-item bg-transparent px-0 border-light d-flex align-items-center py-3">
                        <i class="fas fa-phone-alt text-secondary w-25 text-center fs-5"></i>
                        <span class="text-dark fw-medium">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Not Provided" : Model.PhoneNumber)</span>
                    </li>
                    <li class="list-group-item bg-transparent px-0 border-light d-flex align-items-center py-3">
                        <i class="fas fa-map-marker-alt text-secondary w-25 text-center fs-5"></i>
                        <span class="text-dark fw-medium">@(string.IsNullOrEmpty(Model.Address) ? "Not Provided" : Model.Address)</span>
                    </li>
                </ul>

                <a asp-action="EditProfile" class="btn btn-outline-primary rounded-pill w-100 fw-bold py-2 shadow-sm">
                    <i class="fas fa-user-edit me-2"></i>Edit Profile
                </a>
            </div>
        </div>
    </div>
</div>