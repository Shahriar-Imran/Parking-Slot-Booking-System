@model List<ParkingSystem.Models.Booking>

<div class="container mt-4">
    <h2>My Bookings</h2>

    <div class="alert alert-success d-flex justify-content-between align-items-center">
        <span>
            ⚠️ Please read the <strong>Refund Policy</strong> before cancelling your booking.
        </span>
        <button class="btn btn-link text-white" data-bs-toggle="modal" data-bs-target="#refundModal">
            View
        </button>
    </div>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>Slots</th>
                <th>Start</th>
                <th>End</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td>@b.BookingId</td>

                    <td>
                        @foreach (var s in b.BookingSlots)
                        {
                            <span>
                                @s.Slot.SlotNumber (@s.Slot.ParkingArea.VehicleType)
                            </span>
                            <br />
                        }
                    </td>

                    <td>@b.StartTime</td>
                    <td>@b.EndTime</td>
                    <td>৳ @b.TotalAmount</td>

                    <!-- 🔥 STATUS COLUMN -->
                    <td>
                        @if (b.RefundStatus == "Pending")
                        {
                            <span class="badge bg-warning text-dark">Refund Pending</span>
                        }
                        else if (b.RefundStatus == "Success")
                        {
                            <span class="badge bg-success">Refunded</span>
                        }
                        else if (b.RefundStatus == "Failed")
                        {
                            <span class="badge bg-danger">Refund Failed</span>
                        }
                        else if (b.IsCancelled)
                        {
                            <span class="badge bg-secondary">Cancelled</span>
                        }
                        else
                        {
                            <span class="badge bg-primary">Active</span>
                        }
                    </td>

                    <!-- 🔥 ACTIONS -->
                    <td>
                        <div class="d-flex flex-column gap-1">

                            <!-- 🔴 REFUND LOGIC -->
                            @if (b.RefundStatus == "None" && b.StartTime > DateTime.Now)
                            {
                                <!-- ✅ INVOICE -->
                                <a asp-controller="Payment"
                                   asp-action="Confirmation"
                                   asp-route-id="@b.BookingId"
                                   class="btn btn-sm btn-outline-primary">
                                    📄 Invoice
                                </a>
                                <button class="btn btn-danger btn-sm"
                                        data-bs-toggle="modal"
                                        data-bs-target="#cancelModal-@b.BookingId">
                                    Request Cancel
                                </button>
                            }
                            else if (b.RefundStatus == "Pending")
                            {
                                <!-- ✅ INVOICE -->
                                <a asp-controller="Payment"
                                   asp-action="Confirmation"
                                   asp-route-id="@b.BookingId"
                                   class="btn btn-sm btn-outline-primary">
                                    📄 Invoice
                                </a>
                                <button class="btn btn-warning btn-sm" disabled>
                                    Waiting for Admin Approval
                                </button>
                            }
                            else if (b.RefundStatus == "Success")
                            {
                                <button class="btn btn-success btn-sm" disabled>
                                    Refund Completed
                                </button>
                            }
                            else if (b.RefundStatus == "Failed")
                            {
                                <button class="btn btn-danger btn-sm" disabled>
                                    Refund Failed
                                </button>
                            }
                            else if (b.StartTime <= DateTime.Now)
                            {
                                <button class="btn btn-secondary btn-sm" disabled>
                                    Expired
                                </button>
                            }

                        </div>

                        <!-- 🔥 CANCEL MODAL -->
                        <div class="modal fade" id="cancelModal-@b.BookingId" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">

                                    <div class="modal-header">
                                        <h5 class="modal-title">Cancel Booking</h5>
                                        <button class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>

                                    <div class="modal-body">

                                        <p><strong>Booking ID:</strong> @b.BookingId</p>

                                        <p>
                                            Estimated Refund:
                                            <strong class="text-success">
                                                ৳ @b.RefundPreview
                                            </strong>
                                        </p>

                                        <hr />

                                        <!-- 🔥 UPDATED ACTION -->
                                        <form asp-controller="Booking"
                                              asp-action="RequestCancel"
                                              method="post">

                                            <input type="hidden" name="bookingId" value="@b.BookingId" />

                                            <div class="text-end">
                                                <button class="btn btn-danger">
                                                    Confirm Request
                                                </button>
                                            </div>
                                        </form>

                                    </div>

                                </div>
                            </div>
                        </div>

                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- 🔥 REFUND POLICY MODAL -->
<div class="modal fade" id="refundModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h4 class="modal-title">Refund Policy</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <ul>
                    <li>Cancellation is allowed only before the booking start time.</li>
                    <li>Refund is calculated based on time remaining before start:</li>
                    <ul>
                        <li>24h+: 10% deduction</li>
                        <li>12–24h: 25% deduction</li>
                        <li>6–12h: 50% deduction</li>
                        <li>1–6h: 75% deduction</li>
                        <li>&lt;1h: No refund</li>
                    </ul>
                    <li>Refunds are processed after admin approval.</li>
                </ul>
            </div>

        </div>
    </div>
</div>