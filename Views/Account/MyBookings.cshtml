@model List<ParkingSystem.Models.Booking>

<div class="container mt-4">
    <h2>My Bookings</h2>
    <div class="alert alert-success d-flex justify-content-between align-items-center">
        <span>
            ⚠️ Please read the <strong>Refund Policy</strong> before cancelling your booking.
        </span>
        <button class="btn btn-link text-white" data-bs-toggle="modal" data-bs-target="#refundModal">
            View
        </button>
    </div>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>Slots</th>
                <th>Start</th>
                <th>End</th>
                <th>Amount</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td>@b.BookingId</td>

                    <td>
                        @foreach (var s in b.BookingSlots)
                        {
                            <span>
                                @s.Slot.SlotNumber (@s.Slot.ParkingArea.VehicleType)
                            </span>

                            <br />
                        }
                    </td>

                    <td>@b.StartTime</td>
                    <td>@b.EndTime</td>
                    <td>৳ @b.TotalAmount</td>
                    <td>
                        <div class="d-flex flex-column gap-1">

                            @if (b.IsCancelled)
                            {
                                <p class="text-danger">
                                    Cancelled | Refund: ৳ @(b.RefundPreview ?? 0)
                                </p>
                            }

                            <!-- CANCEL BUTTON (UI ONLY) -->
                            @if (!b.IsCancelled && b.StartTime > DateTime.Now)
                            {
                                <!-- DOWNLOAD INVOICE -->
                                <a asp-controller="Payment"
                                   asp-action="Confirmation"
                                   asp-route-id="@b.BookingId"
                                   class="btn btn-sm btn-outline-primary">
                                    📄 Invoice
                                </a>
                                
                                <button class="btn btn-danger btn-sm"
                                        data-bs-toggle="modal"
                                        data-bs-target="#cancelModal-@b.BookingId">
                                    Cancel
                                </button>

                            }
                            else
                            {
                                <button class="btn btn-secondary btn-sm" disabled>
                                    Expired
                                </button>
                            }
                            <div class="modal fade" id="cancelModal-@b.BookingId" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">

                                        <div class="modal-header">
                                            <h5 class="modal-title">Cancel Booking</h5>
                                            <button class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>

                                        <div class="modal-body">

                                            <p><strong>Booking ID:</strong> @b.BookingId</p>

                                            <p>
                                                Refund Amount:
                                                <strong class="text-success">
                                                    ৳ @b.RefundAmount
                                                </strong>
                                            </p>

                                            <hr />

                                            <form asp-controller="Booking" asp-action="CancelBooking" method="post">
                                                <input type="hidden" name="id" value="@b.BookingId" />

                                                <label>Refund Number (bKash/Nagad)</label>
                                                <input type="text" name="refundNumber" class="form-control" required />

                                                <small class="text-muted">
                                                    Money will be returned manually by admin.
                                                </small>

                                                <div class="mt-3 text-end">
                                                    <button class="btn btn-danger">Confirm Cancel</button>
                                                </div>
                                            </form>

                                        </div>

                                    </div>
                                </div>
                            </div>

                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- 🔥 REFUND POLICY MODAL (PLACE HERE) -->
<div class="modal fade" id="refundModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h4 class="modal-title">Refund Policy</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <ul>
                    <li>Cancellation is allowed only before the booking start time.</li>
                    <li>Refund is calculated based on time remaining before start:</li>
                    <ul>
                        <li>In case of cancel booking 24 hours prior to the commencement of the start time, 10% of the slot fare will be deducted;</li>
                        <li>In case of less than 24 hours and more than 12 hours, 25% of the slot fare will be deducted;</li>
                        <li>In case of less than 12 hours and more than 6 hours, 50% of the slot fare will be deducted;</li>
                        <li>In case of less than 6 hours and more than 1 hours, 75% of the slot fare will be deducted;</li>
                        <li>No refund for less than 1 hours;</li>
                    </ul>
                    <li>Refunds are processed manually to the provided mobile number (bKash/Nagad).</li>
                </ul>
            </div>

        </div>
    </div>
</div>
<!-- CANCELLATION POLICY -->
