@model ParkingSystem.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-4 mb-5 align-items-center" style="min-height: 65vh;">
    <div class="col-md-7 col-lg-6 col-xl-5">
        
        <div class="text-center mb-4">
            <h2 class="fw-bold" style="color: var(--primary-color);"><i class="fas fa-parking me-2 text-warning"></i>Parkonic</h2>
            <p class="text-muted mb-0">Start booking your slots today</p>
        </div>

        <div class="card shadow-lg border-0 rounded-4 p-4 p-md-5" style="background: var(--surface-color);">
            <div class="text-center mb-4">
                <h4 class="fw-bold">Create an Account</h4>
                <p class="text-muted small">Fill in your details below to register securely</p>
            </div>
            
            <div class="card-body p-0">
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3 small fw-bold"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label text-secondary small fw-bold text-uppercase"><i class="fas fa-user-circle text-primary me-2"></i>Full Name</label>
                        <input asp-for="FullName" class="form-control bg-light border-0 p-2 custom-input shadow-none" placeholder="Enter your full name" />
                        <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label text-secondary small fw-bold text-uppercase"><i class="fas fa-envelope text-primary me-2"></i>Email Address</label>
                        <input asp-for="Email" class="form-control bg-light border-0 p-2 custom-input shadow-none" placeholder="name@example.com" />
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="form-label text-secondary small fw-bold text-uppercase"><i class="fas fa-lock text-primary me-2"></i>Password</label>
                            <div class="input-group bg-light rounded-3 overflow-hidden">
                                <input asp-for="Password" type="password" class="form-control bg-light border-0 p-2 custom-input shadow-none" placeholder="Password" />
                                <button class="btn bg-light border-0 text-muted shadow-none px-3" type="button" tabindex="-1" onclick="togglePassword('Password', this)">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="ConfirmPassword" class="form-label text-secondary small fw-bold text-uppercase"><i class="fas fa-check-circle text-primary me-2"></i>Confirm</label>
                            <div class="input-group bg-light rounded-3 overflow-hidden">
                                <input asp-for="ConfirmPassword" type="password" class="form-control bg-light border-0 p-2 custom-input shadow-none" placeholder="Confirm" />
                                <button class="btn bg-light border-0 text-muted shadow-none px-3" type="button" tabindex="-1" onclick="togglePassword('ConfirmPassword', this)">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-grid mt-2 mb-3">
                        <button type="submit" class="btn btn-primary rounded-pill shadow-sm py-2 fw-bold text-white d-flex justify-content-center align-items-center gap-2">
                            Create Account <i class="fas fa-user-plus"></i>
                        </button>
                    </div>
                </form>

                <div class="text-center mt-4">
                    <p class="text-muted small mb-0">
                        Already have an account? 
                        <a asp-action="Login" class="fw-bold text-primary text-decoration-none" style="transition: opacity 0.3s;" onmouseover="this.style.opacity=0.8" onmouseout="this.style.opacity=1">Login here</a>
                    </p>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword(id, btn) {
            const el = document.getElementById(id);
            const icon = btn.querySelector('i');
            if (el.type === 'password') {
                el.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                el.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }
    </script>
}