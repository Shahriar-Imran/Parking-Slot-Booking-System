@using Microsoft.AspNetCore.Identity
@using ParkingSystem.Models
@inject SignInManager<ParkingSystem.Models.ApplicationUser> SignInManager
@inject UserManager<ParkingSystem.Models.ApplicationUser> UserManager
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Parking System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
</head>
<body class="d-flex flex-column min-vh-100">

    <!-- NAVBAR START -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    🚗 Parking System
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav"
                        aria-controls="navbarNav"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    <!-- Left Menu -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Slot" asp-action="Availability">
                                Slot Availability
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="About">
                                About
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contact">
                                Contact Us
                            </a>
                        </li>
                    </ul>

                    <!-- Right Menu -->
                    <ul class="navbar-nav">

                        @if (SignInManager.IsSignedIn(User))
                        {
                            var currentUser = await UserManager.GetUserAsync(User);

                            <!-- Show User Name -->
                            

                            <!-- ✅ Admin Dashboard (FIXED POSITION) -->
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                                        Admin Dashboard
                                    </a>
                                </li>
                            }

                            <div class="dropdown">
                                <button class="btn d-flex align-items-center gap-2 text-white border-0"
                                        style="background: transparent;"
                                        data-bs-toggle="dropdown">

                                    <!-- Profile Image -->
                                    <img src="@(string.IsNullOrEmpty(currentUser.ProfileImage) ? "/images/default-user.png" : currentUser.ProfileImage)"
                                         class="rounded-circle"
                                         width="35"
                                         height="35"
                                         style="object-fit: cover;" />

                                    <!-- Name -->
                                    <span>@currentUser.FullName</span>
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end shadow">

                                    <li class="px-3 py-2 border-bottom">
                                        <strong>@currentUser.FullName</strong><br />
                                        <small class="text-muted">@currentUser.Email</small>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            👤 Profile
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="MyBookings">
                                            📋 Booking History
                                        </a>
                                    </li>

                                    <li><hr class="dropdown-divider"></li>

                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger">
                                                🚪 Logout
                                            </button>
                                        </form>
                                    </li>

                                </ul>
                            </div>
                        }
                        else
                        {
                            <!-- Login -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    Login
                                </a>
                            </li>

                            <!-- Register -->
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm ms-2"
                                   asp-controller="Account"
                                   asp-action="Register">
                                    Register
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <!-- NAVBAR END -->
    <!-- MAIN CONTENT -->
    <main class="flex-grow-1">
        <div class="container mt-4">
            @RenderBody()
        </div>
    </main>


    <!-- FOOTER -->
    <footer class="bg-dark text-white text-center p-3 fixed-footer">
        <p class="mb-0">
            © @DateTime.Now.Year - Parking Slot Booking System | All Rights Reserved
        </p>
    </footer>

    
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/slot.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>