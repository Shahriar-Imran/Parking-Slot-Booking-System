@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5 mt-2">
    <div class="row align-items-center mb-5 g-5">
        <div class="col-lg-6">
            <h1 class="display-4 fw-bold" style="color: var(--primary-color);">Revolutionizing <br> <span class="text-info">Urban Mobility</span></h1>
            <p class="lead text-muted mt-4" style="line-height: 1.8;">We believe that finding a parking spot shouldn't be the hardest part of your day. Our state-of-the-art booking system is designed to make parking seamless, secure, and completely stress-free.</p>
        </div>
        <div class="col-lg-6 position-relative">
            <div class="position-absolute end-0 bottom-0 bg-warning text-dark p-3 rounded-circle shadow-lg d-flex align-items-center justify-content-center" style="width: 100px; height: 100px; transform: translate(15%, 15%); z-index: 2;">
                <div class="text-center">
                    <h5 class="fw-bold mb-0">100%</h5>
                    <small style="font-size: 0.7rem;" class="fw-bold text-uppercase">Secure</small>
                </div>
            </div>
            <img src="https://images.unsplash.com/photo-1573348722427-f1d6819fdf98?q=80&w=800&auto=format&fit=crop" alt="Smart Parking" class="img-fluid rounded-5 shadow-lg w-100 position-relative" style="height: 380px; object-fit: cover; z-index: 1;" />
        </div>
    </div>

    <!-- Core Values -->
    <div class="row g-4 text-center mt-5 mb-5 pt-4">
        <div class="col-md-4">
            <div class="card h-100 p-5 border-0 shadow-sm rounded-4 h-100" style="background: var(--surface-color);">
                <div class="mb-4">
                    <i class="fas fa-shield-alt text-primary" style="font-size: 3.5rem;"></i>
                </div>
                <h4 class="fw-bold text-dark mb-3">Security First</h4>
                <p class="text-muted">High-tech 24/7 surveillance networks and dedicated on-site personnel ensuring absolute vehicle security.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 p-5 border-0 shadow-lg rounded-4 h-100 position-relative overflow-hidden" style="background: var(--primary-color);">
                <div class="position-absolute opacity-10 top-0 end-0 m-3">
                    <i class="fas fa-bolt" style="font-size: 6rem; color: white;"></i>
                </div>
                <div class="mb-4 position-relative z-index-1">
                    <i class="fas fa-bolt text-warning" style="font-size: 3.5rem;"></i>
                </div>
                <h4 class="fw-bold text-white mb-3 position-relative z-index-1">Instant Convenience</h4>
                <p class="text-light opacity-75 position-relative z-index-1">100% automated booking. Reserve, pay, and park within exactly three taps on your mobile device.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 p-5 border-0 shadow-sm rounded-4 h-100" style="background: var(--surface-color);">
                <div class="mb-4">
                    <i class="fas fa-leaf text-success" style="font-size: 3.5rem;"></i>
                </div>
                <h4 class="fw-bold text-dark mb-3">Eco-Friendly</h4>
                <p class="text-muted">Minimizing carbon emissions by eliminating the need to endlessly circle blocks hunting for vacant spaces.</p>
            </div>
        </div>
    </div>
</div>
