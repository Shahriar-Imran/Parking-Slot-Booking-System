@{
    ViewData["Title"] = "Contact Us";
}

<div class="container py-5 mt-2 mb-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold" style="color: var(--primary-color);">Get In Touch</h1>
        <p class="lead text-muted">We'd love to hear from you. Our team is always here to help.</p>
    </div>

    <div class="row g-5 align-items-center">
        <!-- Contact Info Cards -->
        <div class="col-lg-5">
            <div class="d-flex flex-column gap-3">
                
                <!-- Location -->
                <div class="card border-0 shadow-sm rounded-4 p-4 d-flex flex-row align-items-center gap-4 bg-white hover-lift">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 60px; height: 60px;">
                        <i class="fas fa-map-marker-alt fs-3"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold text-dark mb-1">Headquarters</h5>
                        <p class="text-muted mb-0 small">E-14/X, ICT Tower, Agargaon, Dhaka-1207</p>
                    </div>
                </div>

                <!-- Email -->
                <div class="card border-0 shadow-sm rounded-4 p-4 d-flex flex-row align-items-center gap-4 bg-white hover-lift">
                    <div class="bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 60px; height: 60px;">
                        <i class="fas fa-envelope-open-text fs-3"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold text-dark mb-1">Email Support</h5>
                        <p class="text-muted mb-0 small">support@parkingsystem.com</p>
                    </div>
                </div>

                <!-- Phone -->
                <div class="card border-0 shadow-sm rounded-4 p-4 d-flex flex-row align-items-center gap-4 bg-white hover-lift">
                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 60px; height: 60px;">
                        <i class="fas fa-phone-alt fs-3"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold text-dark mb-1">Hotline 24/7</h5>
                        <p class="text-muted mb-0 small">+880 1890 065004</p>
                    </div>
                </div>

            </div>
        </div>

        <!-- Contact Form UI -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg rounded-5 p-5 h-100" style="background: var(--surface-color);">
                <h3 class="fw-bold text-dark mb-4">Send a Message <i class="fas fa-paper-plane text-warning ms-2"></i></h3>
                <form id="contactForm" onsubmit="handleContactSubmit(event)">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-secondary small fw-bold text-uppercase">Your Name</label>
                            <input type="text" class="form-control bg-light border-0 p-3 rounded-3 custom-input shadow-none" placeholder="John Doe" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small fw-bold text-uppercase">Email Address</label>
                            <input type="email" class="form-control bg-light border-0 p-3 rounded-3 custom-input shadow-none" placeholder="john@example.com" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-secondary small fw-bold text-uppercase">Subject</label>
                            <input type="text" class="form-control bg-light border-0 p-3 rounded-3 custom-input shadow-none" placeholder="How can we help?" required>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label text-secondary small fw-bold text-uppercase">Message</label>
                            <textarea class="form-control bg-light border-0 p-3 rounded-3 custom-input shadow-none" rows="5" placeholder="Write your message here..." required></textarea>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary rounded-pill shadow-sm py-3 px-5 fw-bold w-100 fs-5 text-white" style="border: none;">
                                Send Message <i class="fas fa-paper-plane text-white ms-2"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

    </div>

    <!-- MAPS SECTION -->
    <div class="row mt-5 pt-3">
        <div class="col-12">
            <div class="card border-0 shadow-lg rounded-5 p-2 bg-white">
                <div class="rounded-4 overflow-hidden" style="height: 450px; background: #e9ecef;">
                    <iframe 
                        width="100%" 
                        height="100%" 
                        src="https://maps.google.com/maps?q=ICT%20Tower,%20Agargaon,%20Dhaka-1207&t=&z=15&ie=UTF8&iwloc=&output=embed" 
                        frameborder="0" 
                        scrolling="no" 
                        marginheight="0" 
                        marginwidth="0"
                        style="border:0;" 
                        allowfullscreen="" 
                        loading="lazy">
                    </iframe>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function handleContactSubmit(event) {
        event.preventDefault();
        Swal.fire({
            title: 'Message Sent Successfully!',
            text: 'Our team will get back to you within 24 hours.',
            icon: 'success',
            confirmButtonColor: '#009ffd',
            background: '#ffffff',
            customClass: {
                popup: 'rounded-4 shadow-lg border-0'
            }
        }).then(() => {
            document.getElementById("contactForm").reset();
        });
    }
</script>
