@model ParkingSystem.Models.ParkingSlot

<div class="container mt-4">
    <h2>Add New Slot</h2>

    <form asp-action="CreateSlot" method="post">
        <div class="mb-3">
            <label>Slot Number</label>
            <input asp-for="SlotNumber" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Hourly Rate</label>
            <input asp-for="HourlyRate" class="form-control" />
        </div>

        <button class="btn btn-success">Save</button>
    </form>
</div>