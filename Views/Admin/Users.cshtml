@model List<ParkingSystem.Models.ApplicationUser>
@using Microsoft.AspNetCore.Identity
@inject UserManager<ParkingSystem.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = "Manage Users";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0 text-dark"><i class="fas fa-users-cog text-primary me-2"></i>User Management</h2>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table table-hover table-borderless mb-0 align-middle">
                <thead class="bg-light text-secondary small text-uppercase">
                    <tr>
                        <th class="ps-4">Full Name</th>
                        <th>Email</th>
                        <th class="pe-4 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top">
                    @{
                        var currentUserEmail = User.Identity.Name;
                        bool isMainAdmin = currentUserEmail == "admin@gmail.com";
                    }
                    @if (Model != null && Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark py-3">
                                    <a asp-action="UserProfile" asp-route-id="@user.Id" class="text-decoration-none text-dark hover-primary d-flex align-items-center gap-2">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        @user.FullName
                                    </a>
                                </td>
                                <td class="text-secondary fw-semibold">@user.Email</td>

                                <td class="pe-4 text-end">
                                    @{
                                        var isAdmin = await UserManager.IsInRoleAsync(user, "Admin");
                                    }

                                    <div class="d-flex flex-wrap justify-content-end align-items-center gap-2">
                                        <!-- 🔥 ROLE BADGE -->
                                        @if (user.Email == "admin@gmail.com")
                                        {
                                            <span class="badge bg-dark rounded-pill px-3 py-2 shadow-sm text-warning d-flex align-items-center me-2"><i class="fas fa-crown me-2"></i>Main Admin</span>
                                        }
                                        else if (isAdmin)
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2 shadow-sm d-flex align-items-center me-2"><i class="fas fa-shield-alt me-2"></i>Admin</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2 shadow-sm d-flex align-items-center me-2"><i class="fas fa-user-check me-2"></i>User</span>
                                        }

                                        <!-- 🔥 MAKE ADMIN -->
                                        @if (!isAdmin && isMainAdmin)
                                        {
                                            <form asp-action="MakeAdmin" method="post" class="m-0">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button class="btn btn-outline-warning btn-sm rounded-pill shadow-sm px-3 fw-bold flex-shrink-0">
                                                    <i class="fas fa-user-shield me-1"></i> Make Admin
                                                </button>
                                            </form>
                                        }

                                        <!-- 🔥 REMOVE ADMIN -->
                                        @if (isAdmin && isMainAdmin && user.Email != "admin@gmail.com")
                                        {
                                            <form asp-action="RemoveAdmin" method="post" class="m-0">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button class="btn btn-outline-dark btn-sm rounded-pill shadow-sm px-3 fw-bold flex-shrink-0">
                                                    <i class="fas fa-user-minus me-1"></i> Remove Admin
                                                </button>
                                            </form>
                                        }

                                        <!-- 🔥 DELETE -->
                                        @{
                                            var isTargetAdmin = await UserManager.IsInRoleAsync(user, "Admin");
                                        }

                                        @if (user.Email == "admin@gmail.com")
                                        {
                                            <button class="btn btn-light border btn-sm rounded-pill px-3 fw-bold text-muted flex-shrink-0" disabled>
                                                <i class="fas fa-lock me-1"></i> Protected
                                            </button>
                                        }
                                        else if (isTargetAdmin && !isMainAdmin)
                                        {
                                            <button class="btn btn-light border btn-sm rounded-pill px-3 fw-bold text-muted flex-shrink-0" disabled>
                                                <i class="fas fa-user-lock me-1"></i> Protected
                                            </button>
                                        }
                                        else
                                        {
                                            <form asp-action="DeleteUser" method="post" class="m-0">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button class="btn btn-danger bg-gradient btn-sm rounded-pill shadow-sm px-3 fw-bold flex-shrink-0" onclick="return confirm('Delete user globally?');">
                                                    <i class="fas fa-trash me-1"></i> Delete
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                <i class="fas fa-users-slash fs-2 mb-3 text-light"></i>
                                <p class="mb-0">No users found.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>