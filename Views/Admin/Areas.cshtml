@model List<ParkingSystem.Models.ParkingArea>

@{
    ViewData["Title"] = "Manage Parking Areas";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0 text-dark"><i class="fas fa-map-marked-alt text-info me-2"></i>Parking Areas</h2>
        <a asp-controller="Admin" asp-action="CreateArea" class="btn btn-primary rounded-pill shadow-sm px-4 fw-bold">
            <i class="fas fa-plus-circle me-1"></i>Add Area
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table table-hover table-borderless mb-0 align-middle">
                <thead class="bg-light text-secondary small text-uppercase">
                    <tr>
                        <th class="ps-4">Block Designation</th>
                        <th>Vehicle Type</th>
                        <th>Hourly Rate</th>
                        <th class="pe-4 text-end">Action</th>
                    </tr>
                </thead>
                <tbody class="border-top">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="fas fa-layer-group fs-2 mb-3 text-light"></i>
                                <p class="mb-0">No parking areas created yet.</p>
                            </td>
                        </tr>
                    }
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark py-3">
                                <div class="d-inline-flex align-items-center justify-content-center bg-info bg-opacity-10 text-info rounded text-dark px-3 py-2 shadow-sm border border-info border-opacity-25">
                                    <i class="fas fa-bars border-end border-info border-opacity-50 pe-2 me-2"></i> Block @a.BlockNumber
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-secondary bg-opacity-10 text-secondary border rounded-pill px-3 py-2 shadow-sm fw-medium fs-6"><i class="fas fa-car-side text-warning me-2"></i>@a.VehicleType</span>
                            </td>
                            <td class="fw-bold text-success fs-5">৳@a.HourlyRate</td>
                            <td class="pe-4 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="EditArea" asp-route-id="@a.AreaId" class="btn btn-outline-warning btn-sm rounded-pill shadow-sm px-4 py-2 fw-bold d-flex align-items-center">
                                        <i class="fas fa-edit me-2"></i>Edit
                                    </a>
                                    <a asp-action="DeleteArea" asp-route-id="@a.AreaId" class="btn btn-danger btn-sm rounded-pill shadow-sm px-4 py-2 fw-bold d-flex align-items-center" onclick="return confirm('Delete this area and all its slots globally?');">
                                        <i class="fas fa-trash-alt me-2"></i>Remove
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>