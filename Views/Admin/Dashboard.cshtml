@model ParkingSystem.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Command Center";
}

<div class="d-flex justify-content-between align-items-end mb-4 mt-2 border-bottom pb-3">
    <div>
        <h2 class="fw-bold mb-0 text-dark" style="letter-spacing: -0.5px;"><i class="fas fa-layer-group text-primary me-2"></i>Admin Dashboard</h2>
        <p class="text-muted small mb-0 mt-2">Executive telemetry and structural block management</p>
    </div>
    <div class="text-end">
        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill"><i class="fas fa-circle ms-1 me-2 small"></i>System Online</span>
    </div>
</div>

<!-- 🔥 CORE TELEMETRY METRICS -->
<div class="row g-4 mb-5">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 hover-lift h-100 bg-white" style="border-left: 5px solid #0d6efd !important;">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-2" style="font-size: 0.75rem; letter-spacing: 1px;">Registered Users</h6>
                    <h3 class="text-dark fw-bold mb-0">@Model.TotalUsers</h3>
                </div>
                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                    <i class="fas fa-users fs-5"></i>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 hover-lift h-100 bg-white" style="border-left: 5px solid #198754 !important;">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-2" style="font-size: 0.75rem; letter-spacing: 1px;">Processed Bookings</h6>
                    <h3 class="text-dark fw-bold mb-0">@Model.TotalBookings</h3>
                </div>
                <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                    <i class="fas fa-calendar-check fs-5"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 hover-lift h-100 bg-white" style="border-left: 5px solid #ffc107 !important;">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-2" style="font-size: 0.75rem; letter-spacing: 1px;">Active Hardware Slots</h6>
                    <h3 class="text-dark fw-bold mb-0">@Model.TotalSlots</h3>
                </div>
                <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                    <i class="fas fa-parking fs-5"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 hover-lift h-100 bg-white" style="border-left: 5px solid #6f42c1 !important;">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-2" style="font-size: 0.75rem; letter-spacing: 1px;">Net Revenue Yield</h6>
                    <h3 class="text-dark fw-bold mb-0">৳@Model.TotalRevenue.ToString("N2")</h3>
                </div>
                <div class="bg-purple bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; background-color: rgba(111, 66, 193, 0.1); color: #6f42c1;">
                    <i class="fas fa-wallet fs-5"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-5 mb-5">
    
    <!-- LEFT COLUMN: RECENT BOOKINGS & QUICK ACTIONS -->
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold text-dark mb-0"><i class="fas fa-stream text-secondary me-2"></i>Recent Network Activity</h5>
            <a asp-action="BookingHistory" class="text-decoration-none small fw-bold">View Global Log &rarr;</a>
        </div>
        
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5 bg-white">
            <div class="table-responsive">
                <table class="table table-hover table-borderless align-middle mb-0">
                    <thead class="bg-light text-secondary text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                        <tr>
                            <th class="ps-4 py-3">Reference ID</th>
                            <th class="py-3">Client</th>
                            <th class="py-3">Timestamp</th>
                            <th class="py-3 text-end pe-4">Gross Value</th>
                        </tr>
                    </thead>
                    <tbody class="border-top">
                        @if (Model.RecentBookings.Any())
                        {
                            foreach (var b in Model.RecentBookings)
                            {
                                <tr>
                                    <td class="ps-4 py-3"><span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25">#@b.BookingId</span></td>
                                    <td class="py-3 fw-bold text-dark">@(b.User?.Email ?? "Anonymous")</td>
                                    <td class="py-3 text-muted small"><i class="far fa-clock me-1"></i>@b.CreatedAt.ToString("MMM dd, HH:mm")</td>
                                    <td class="py-3 text-end pe-4 fw-bold @((b.IsCancelled || b.RefundStatus == "Success") ? "text-danger" : "text-success")">
                                        @((b.IsCancelled || b.RefundStatus == "Success") ? $"-৳{b.RefundAmount ?? b.TotalAmount}" : $"৳{b.TotalAmount}")
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="fas fa-inbox fs-1 mb-3 text-light"></i>
                                    <p class="mb-0">No active bookings detected in the system yet.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <h5 class="fw-bold text-dark mb-3"><i class="fas fa-cogs text-secondary me-2"></i>System Controls</h5>
        <div class="row g-3">
            <div class="col-sm-4">
                <a asp-controller="Admin" asp-action="Users" class="text-decoration-none h-100 d-block">
                    <div class="card border border-light shadow-sm bg-white rounded-3 hover-lift text-center p-3 h-100">
                        <i class="fas fa-users-cog fs-4 text-info mb-2 mt-1"></i>
                        <h6 class="fw-bold text-dark mb-0 small">Manage Users</h6>
                    </div>
                </a>
            </div>
            <div class="col-sm-4">
                <a asp-controller="Admin" asp-action="Areas" class="text-decoration-none h-100 d-block">
                    <div class="card border border-light shadow-sm bg-white rounded-3 hover-lift text-center p-3 h-100">
                        <i class="fas fa-map-marked-alt fs-4 text-primary mb-2 mt-1"></i>
                        <h6 class="fw-bold text-dark mb-0 small">Parking Areas</h6>
                    </div>
                </a>
            </div>
            <div class="col-sm-4">
                <a asp-controller="Admin" asp-action="Slots" class="text-decoration-none h-100 d-block">
                    <div class="card border border-light shadow-sm bg-white rounded-3 hover-lift text-center p-3 h-100">
                        <i class="fas fa-car fs-4 text-warning mb-2 mt-1"></i>
                        <h6 class="fw-bold text-dark mb-0 small">Hardware Slots</h6>
                    </div>
                </a>
            </div>
        </div>

    </div>

    <!-- RIGHT COLUMN: REVENUE ENGINE -->
    <div class="col-lg-4">
        <h5 class="fw-bold text-dark mb-3"><i class="fas fa-file-pdf text-danger me-2"></i>Financial Exports</h5>
        
        <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden">
            <div class="bg-light border-bottom p-4 text-center">
                <div class="d-inline-flex align-items-center justify-content-center bg-white shadow-sm rounded-circle mb-3" style="width: 70px; height: 70px;">
                    <i class="fas fa-print fs-3 text-danger"></i>
                </div>
                <h6 class="fw-bold text-dark mb-1">Custom Revenue PDF</h6>
                <p class="text-muted small mb-0">Isolate metrics by explicit dates</p>
            </div>
            <div class="card-body p-4">
                <form action="@Url.Action("RevenueReport", "Admin")" method="get" target="_blank" class="d-flex flex-column gap-3">
                    <div>
                        <label for="startDate" class="form-label fw-bold text-secondary text-uppercase small mb-1"><i class="fas fa-calendar-alt text-primary me-1"></i> Start Date</label>
                        <input type="date" id="startDate" name="startDate" class="form-control bg-light border-0 px-3 py-2 rounded-3" required />
                    </div>
                    <div>
                        <label for="endDate" class="form-label fw-bold text-secondary text-uppercase small mb-1"><i class="fas fa-calendar-check text-primary me-1"></i> End Date</label>
                        <input type="date" id="endDate" name="endDate" class="form-control bg-light border-0 px-3 py-2 rounded-3" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold shadow mt-2 hover-lift d-flex justify-content-center align-items-center">
                        <i class="fas fa-download me-2"></i> Compile PDF Report
                    </button>
                    <p class="text-center text-muted mt-2 mb-0" style="font-size: 0.70rem;">Powered by HTML2PDF Engine.</p>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.10)!important;
    }
</style>