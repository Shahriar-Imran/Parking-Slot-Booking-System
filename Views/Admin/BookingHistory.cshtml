@model List<ParkingSystem.Models.Booking>

<div class="container mt-4">
    <h2>Booking History</h2>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>User</th>
                <th>Slots</th>
                <th>Start</th>
                <th>End</th>
                <th>Amount</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var b in Model)
            {
                var isPast = b.EndTime <= DateTime.Now;

                <tr>
                    <td>@b.BookingId</td>
                    <td>@b.UserId</td>

                    <td>
                        @foreach (var s in b.BookingSlots)
                        {
                            <span>
                                @s.Slot.SlotNumber (@s.Slot.ParkingArea.VehicleType)
                            </span>

                            <br />
                        }
                    </td>

                    <td>@b.StartTime</td>
                    <td>@b.EndTime</td>
                    <td>৳ @b.TotalAmount</td>

                    <td>
                        <form method="post" asp-action="CancelBooking">
                            <input type="hidden" name="id" value="@b.BookingId" />

                            <button type="submit"
                                    class="btn btn-danger"
                            @(isPast ? "disabled" : "")>
                                Cancel
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>