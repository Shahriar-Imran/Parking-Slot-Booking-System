@model List<ParkingSystem.Models.Booking>

<div class="container mt-4">
    <h2>Booking History</h2>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>User</th>
                <th>Slots</th>
                <th>Start</th>
                <th>End</th>
                <th>Amount</th>
                <th>Action</th>
                <th>Request</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var b in Model)
            {
                var isPast = b.EndTime <= DateTime.Now;

                <tr>
                    <td>@b.BookingId</td>
                    <td>@b.UserId</td>

                    <td>
                        @foreach (var s in b.BookingSlots)
                        {
                            <span>
                                @s.Slot.SlotNumber (@s.Slot.ParkingArea.VehicleType)
                            </span>

                            <br />
                        }
                    </td>

                    <td>@b.StartTime</td>
                    <td>@b.EndTime</td>
                    <td>৳ @b.TotalAmount</td>

                    <td>
                        @if (!b.IsCancelled && b.StartTime > DateTime.Now)
                        {
                            <form asp-action="CancelBooking" method="post">
                                <input type="hidden" name="id" value="@b.BookingId" />
                                <button class="btn btn-danger btn-sm">
                                    Cancel
                                </button>
                            </form>
                        }
                        else if (b.IsCancelled)
                        {
                            <button class="btn btn-secondary btn-sm" disabled>
                                Cancelled
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-sm" disabled>
                                Expired
                            </button>
                        }
                    </td>
                    <td>
                        @if (b.RefundStatus == "Pending")
                        {
                            <form asp-action="ApproveRefund" method="post" style="display:inline;">
                                <input type="hidden" name="bookingId" value="@b.BookingId" />
                                <button class="btn btn-success btn-sm">
                                    Approve
                                </button>
                            </form>

                            <form asp-action="RejectRefund" method="post" style="display:inline;">
                                <input type="hidden" name="bookingId" value="@b.BookingId" />
                                <button class="btn btn-danger btn-sm">
                                    Reject
                                </button>
                            </form>
                        }
                        else if (b.RefundStatus == "Success")
                        {
                            <span class="badge bg-success">Refunded</span>
                        }
                        else if (b.RefundStatus == "Failed")
                        {
                            <span class="badge bg-danger">Failed</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No Request</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>