@model ParkingSystem.Models.ParkingArea
@using ParkingSystem.Models

@if (ViewBag.ErrorMessage != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: '@ViewBag.ErrorMessage',
                confirmButtonColor: '#d33'
            });
        });
    </script>
}

<div class="row justify-content-center mt-4 mb-5 flex-grow-1 align-items-center" style="min-height: 50vh;">
    <div class="col-md-7 col-lg-6 col-xl-5">

        <div class="card shadow-lg border-0 rounded-4 p-4 p-md-5" style="background: var(--surface-color);">
            <div class="text-center mb-4">
                <div class="d-inline-flex justify-content-center align-items-center bg-warning bg-opacity-10 rounded-circle text-warning mb-3 shadow-sm" style="width: 65px; height: 65px;">
                    <i class="fas fa-edit fs-3"></i>
                </div>
                <h4 class="fw-bold text-dark">Edit Parking Area</h4>
                <p class="text-muted small">Update designation and categorization</p>
            </div>

            <div class="card-body p-0">
                <form asp-action="EditArea" method="post">
                    <input type="hidden" asp-for="AreaId" />

                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold text-uppercase"><i class="fas fa-layer-group text-info me-2"></i>Block Designation</label>
                        <input asp-for="BlockNumber" required class="form-control bg-light border-0 p-3 custom-input shadow-none rounded-3" placeholder="e.g. A, B, North Wing" />
                        <span asp-validation-for="BlockNumber" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold text-uppercase"><i class="fas fa-car-side text-warning me-2"></i>Vehicle Category</label>
                        <select asp-for="VehicleType" class="form-select bg-light border-0 p-3 custom-input shadow-none rounded-3 fw-bold text-dark"
                                asp-items="Html.GetEnumSelectList<VehicleType>()">
                        </select>
                    </div>

                    <div class="mb-5">
                        <label class="form-label text-secondary small fw-bold text-uppercase"><i class="fas fa-money-bill-wave text-success me-2"></i>Hourly Configuration (৳)</label>
                        <input asp-for="HourlyRate" class="form-control bg-light border-0 p-3 custom-input shadow-none rounded-3" placeholder="0.00" type="number" step="0.01" />
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4 gap-3">
                        <a asp-action="Areas" class="btn btn-light border rounded-pill fw-bold text-secondary flex-grow-1 py-3 shadow-sm">Cancel</a>
                        <button type="submit" class="btn btn-warning rounded-pill shadow-sm py-3 fw-bold text-dark flex-grow-1">
                            Commit Changes <i class="fas fa-save ms-2"></i>
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>