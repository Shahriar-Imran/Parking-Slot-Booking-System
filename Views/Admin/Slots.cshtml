@model List<ParkingSystem.Models.ParkingSlot>

@{
    ViewData["Title"] = "Manage Slots";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0 text-dark"><i class="fas fa-car text-warning me-2"></i>Slot Management</h2>
        <a asp-action="CreateSlot" class="btn btn-primary rounded-pill shadow-sm px-4 fw-bold">
            <i class="fas fa-plus-circle me-1"></i>Add Slot
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table table-hover table-borderless mb-0 align-middle">
                <thead class="bg-light text-secondary small text-uppercase">
                    <tr>
                        <th class="ps-4">Slot Number</th>
                        <th>Block</th>
                        <th>Area Details</th>
                        <th>Hourly Rate</th>
                        <th>Status</th>
                        <th class="pe-4 text-end">Action</th>
                    </tr>
                </thead>
                <tbody class="border-top">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var slot in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark py-3">
                                    <div class="d-inline-flex align-items-center justify-content-center bg-light text-dark rounded-circle shadow-sm border border-secondary border-opacity-25 fs-5" style="width: 45px; height: 45px;">
                                        @slot.SlotNumber
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-3 py-2 shadow-sm rounded-pill fw-medium">Block @slot.ParkingArea?.BlockNumber</span>
                                </td>
                                <td class="text-secondary fw-semibold">
                                    <i class="fas fa-tag text-muted me-1"></i> @slot.ParkingArea?.VehicleType
                                </td>
                                <td class="fw-bold text-success">৳@slot.ParkingArea?.HourlyRate</td>
                                <td>
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill shadow-sm"><i class="fas fa-check-circle me-1"></i>Available</span>
                                </td>
                                <td class="pe-4 text-end">
                                    <form asp-action="DeleteSlot" method="post" class="m-0" onsubmit="return confirm('Are you sure you want to completely remove this slot?');">
                                        <input type="hidden" name="id" value="@slot.SlotId" />
                                        <button class="btn btn-outline-danger btn-sm rounded-pill shadow-sm px-4 py-2 fw-bold d-inline-flex align-items-center">
                                            <i class="fas fa-trash me-2"></i>Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fas fa-parking fs-2 mb-3 text-light"></i>
                                <p class="mb-0">No slots found.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>