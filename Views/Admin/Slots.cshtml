@model List<ParkingSystem.Models.ParkingSlot>

@{
    ViewData["Title"] = "Manage Slots";
}

<div class="container mt-4">

    <h2 class="mb-3">Slot Management</h2>

    <!-- Add Slot Button -->
    <a asp-action="CreateSlot" class="btn btn-success mb-3">
        ➕ Add New Slot
    </a>

    <table class="table table-bordered table-hover shadow">

        <thead class="table-dark">
            <tr>
                <th>Slot Number</th>
                <th>Block Number</th>
                <th>Area</th>
                <th>Hourly Rate</th>
                <th>Status</th>
                <th style="width:200px;">Action</th>
            </tr>
        </thead>

        <tbody>

            @if (Model != null && Model.Any())
            {
                foreach (var slot in Model)
                {
                    <tr>
                        <td>@slot.SlotNumber</td>
						<td>@slot.ParkingArea?.BlockNumber</td>
                        <td>@slot.ParkingArea.VehicleType (Block @slot.ParkingArea.BlockNumber)</td>
                        <td>@slot.ParkingArea?.HourlyRate</td>
                        <td>
                            <span class="badge bg-success">
                                Available
                            </span>
                        </td>

                        <td>
                            

                            <!-- Delete Button -->
                            <form asp-action="DeleteSlot"
                                  method="post"
                                  style="display:inline;"
                                  onsubmit="return confirm('Are you sure to delete this slot?');">

                                <input type="hidden" name="id" value="@slot.SlotId" />

                                <button class="btn btn-danger btn-sm">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center text-danger">
                        No slots found
                    </td>
                </tr>
            }

        </tbody>

    </table>

</div>