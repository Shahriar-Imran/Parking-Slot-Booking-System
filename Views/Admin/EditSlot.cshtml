@model ParkingSystem.Models.ParkingSlot

<div class="container mt-4">
    <h2>Edit Slot</h2>

    <form asp-action="EditSlot" method="post">

        <input type="hidden" asp-for="SlotId" />

        <!-- Slot Number -->
        <div class="mb-3">
            <label>Slot Number</label>
            <input asp-for="SlotNumber" class="form-control" />
        </div>

        <!-- ✅ Parking Area Dropdown -->
        <div class="mb-3">
            <label>Parking Area</label>
            <select asp-for="AreaId" class="form-control"
                    asp-items="@(new SelectList(ViewBag.Areas, "AreaId", "Name"))">
                <option value="">Select Area</option>
            </select>
        </div>

        <button class="btn btn-primary">Update</button>
    </form>
</div>