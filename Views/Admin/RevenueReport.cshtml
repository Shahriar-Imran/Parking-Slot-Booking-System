@model ParkingSystem.ViewModels.RevenueReportViewModel

@{
    Layout = null; // Important: Strip navigation layout to prevent PDF clutter
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.PeriodType Revenue Report</title>
    <!-- Use basic Bootstrap CDN to ensure PDF layout works without local CSS issues -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- HTML2PDF CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <style>
        body { background-color: #f8f9fa; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .report-container { max-width: 800px; margin: 0 auto; background: white; padding: 40px; }
        .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #0d6efd; padding-bottom: 15px; margin-bottom: 30px; }
        .header-logo { font-size: 24px; font-weight: bold; color: #0d6efd; }
        .report-title { text-align: right; }
        .report-title h2 { margin: 0; color: #343a40; font-weight: 700; }
        .report-title p { margin: 0; color: #6c757d; }
        .metrics-grid { display: flex; gap: 20px; margin-bottom: 30px; }
        .metric-card { flex: 1; background: #f8f9fa; border-radius: 8px; padding: 20px; text-align: center; border: 1px solid #dee2e6; }
        .metric-card h5 { margin: 0; color: #6c757d; font-size: 14px; text-transform: uppercase; letter-spacing: 1px; }
        .metric-card h3 { margin: 10px 0 0 0; color: #0d6efd; font-weight: bold; }
        .table th { background-color: #f8f9fa; text-transform: uppercase; font-size: 12px; color: #495057; }
        .total-row { font-weight: bold; background-color: #e9ecef !important; }
        #loading-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.9); display: flex; justify-content: center; align-items: center; z-index: 1000; flex-direction: column; }
    </style>
</head>
<body>

    <div id="loading-overlay">
        <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;"></div>
        <h4 class="text-primary">Generating PDF...</h4>
        <p class="text-muted">Please wait, this window will close automatically.</p>
    </div>

    <!-- The actual report to be turned into a PDF -->
    <div id="report-content" class="report-container">
        
        <div class="header">
            <div class="header-logo">Smart Parking System</div>
            <div class="report-title">
                <h2>@Model.PeriodType Revenue Report</h2>
                <p>Date Range: @Model.DateRange</p>
            </div>
        </div>

        <div class="metrics-grid">
            <div class="metric-card">
                <h5>Total Revenue</h5>
                <h3>৳@Model.TotalRevenue.ToString("F2")</h3>
            </div>
            <div class="metric-card">
                <h5>Total Active Slots Booked</h5>
                <h3>@Model.TotalCompletedBookings</h3>
            </div>
            <div class="metric-card">
                <h5>Active Operating Blocks</h5>
                <h3>@Model.AreaRevenues.Count</h3>
            </div>
        </div>

        <h5 class="mb-3 fw-bold text-dark border-bottom pb-2 mt-4">Successful Bookings Log</h5>
        <table class="table table-sm table-bordered align-middle mb-4" style="font-size: 13px;">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Customer Email</th>
                    <th>Booking Time</th>
                    <th>Reservation Target</th>
                    <th class="text-end">Amount</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.SuccessfulBookings.Any())
                {
                    foreach (var booking in Model.SuccessfulBookings)
                    {
                        <tr>
                            <td>#@booking.BookingId</td>
                            <td>@(booking.User?.Email ?? "N/A")</td>
                            <td>@booking.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>@booking.StartTime.ToString("MMM dd, HH:mm")</td>
                            <td class="text-end text-success fw-bold">৳@booking.TotalAmount.ToString("F2")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted py-3">No successful bookings in this period.</td></tr>
                }
            </tbody>
        </table>

        <!-- CANCELLED BOOKINGS -->
        <h5 class="mb-3 fw-bold text-dark border-bottom pb-2 mt-4">Cancelled / Refunded Bookings Log</h5>
        <table class="table table-sm table-bordered align-middle mb-5" style="font-size: 13px;">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Customer Email</th>
                    <th>Refund Status</th>
                    <th class="text-end">Booking Total</th>
                    <th class="text-end text-danger">Refund Deducted</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.CancelledBookings.Any())
                {
                    foreach (var booking in Model.CancelledBookings)
                    {
                        var refundAmt = booking.RefundAmount ?? booking.RefundPreview ?? 0;
                        <tr>
                            <td>#@booking.BookingId</td>
                            <td>@(booking.User?.Email ?? "N/A")</td>
                            <td><span class="badge @(booking.RefundStatus == "Success" ? "bg-secondary" : "bg-warning text-dark")">@(string.IsNullOrEmpty(booking.RefundStatus) ? "None" : booking.RefundStatus)</span></td>
                            <td class="text-end">৳@booking.TotalAmount.ToString("F2")</td>
                            <td class="text-end text-danger fw-bold">-৳@refundAmt.ToString("F2")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted py-3">No cancellations in this period.</td></tr>
                }
            </tbody>
        </table>

        <h5 class="mb-3 fw-bold text-dark border-bottom pb-2">Revenue Breakdown by Block</h5>
        
        <table class="table table-bordered align-middle">
            <thead>
                <tr>
                    <th>Location Block</th>
                    <th>Vehicle Type</th>
                    <th class="text-center">Total Slot Bookings</th>
                    <th class="text-end">Revenue Generated</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.AreaRevenues.Any())
                {
                    foreach (var area in Model.AreaRevenues)
                    {
                        <tr>
                            <td class="fw-bold">@area.BlockNumber</td>
                            <td><span class="badge bg-secondary">@area.VehicleType</span></td>
                            <td class="text-center">@area.CompletedBookings</td>
                            <td class="text-end text-success fw-bold">৳@area.Revenue.ToString("F2")</td>
                        </tr>
                    }
                    <tr class="total-row">
                        <td colspan="3" class="text-end">NET TOTAL:</td>
                        <td class="text-end text-success fs-5">৳@Model.TotalRevenue.ToString("F2")</td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">No revenue generated in this period.</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-5 pt-3 border-top text-center text-muted small">
            <p class="mb-0">Generated by Admin System on @DateTime.Now.ToString("f")</p>
            <p>Confidential Financial Document.</p>
        </div>

    </div>

    <script>
        // Once the document is loaded, immediately fire the PDF printer
        document.addEventListener("DOMContentLoaded", function () {
            
            var element = document.getElementById('report-content');
            
            var opt = {
              margin:       [0.5, 0, 0.5, 0], // top, left, bottom, right margins
              filename:     '@Model.PeriodType-Revenue-Report.pdf',
              image:        { type: 'jpeg', quality: 0.98 },
              html2canvas:  { scale: 2, useCORS: true },
              jsPDF:        { unit: 'in', format: 'letter', orientation: 'portrait' }
            };

            // Generate and save PDF, then close the tab
            html2pdf().set(opt).from(element).save().then(function() {
                setTimeout(function() {
                    window.close(); // Attempt to close the newly opened tab automatically
                }, 1000);
            });
            
        });
    </script>
</body>
</html>
